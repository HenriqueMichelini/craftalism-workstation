#!/usr/bin/env bash

set -euo pipefail

cat <<'EOF'
Craftalism workstation commands

Implemented now:
  work-status                  Show repo status, docs state, and verification state
  work-context                 Show repo role, ownership, contracts, and verify mode
  work-ownership-check         Explain repo boundaries and handoff points
  work-docs                    Print governance-aware reading order
  work-audit-pack              Print a Codex-ready governance audit pack
  work-checklist               Print implementation and reverification checklist
  work-commit "<message>"      Validate, stage, block unsafe files, commit, and push main
  work-verify                  Run configured local verification or report policy gap
  work-help                    Show this help
  work-version                 Print workstation version
  work-doctor                  Check workstation environment and repo detection

Scaffolded:
  work-contract-change-check   Print the root cross-repo contract change checklist when present
  work-tag                     Structured tagged-release decision with local gates and governance context
  work-release-check           Structured non-tagged release-readiness view with blocking reasons
  work-platform-status         Cross-repo local status plus mapped CI coverage under ~/IdeaProjects
EOF
