#!/usr/bin/env bash

set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "${root}/lib/common.sh"
source "${root}/lib/ci.sh"
source "${root}/lib/release.sh"
source "${root}/policy/repos.sh"
source "${root}/policy/release.sh"

base="${HOME}/IdeaProjects"
repos=(
  craftalism
  craftalism-api
  craftalism-authorization-server
  craftalism-dashboard
  craftalism-deployment
  craftalism-economy
  craftalism-infra
  craftalism-market
)

for repo in "${repos[@]}"; do
  repo_dir="${base}/${repo}"
  if [[ ! -d "${repo_dir}" ]]; then
    print_kv "${repo}" "missing locally"
    continue
  fi

  if git -C "${repo_dir}" rev-parse --show-toplevel >/dev/null 2>&1; then
    branch="$(git -C "${repo_dir}" symbolic-ref --quiet --short HEAD 2>/dev/null || echo unborn)"
    sha="$(git -C "${repo_dir}" rev-parse --short HEAD 2>/dev/null || echo unborn)"
    tree="clean"
    [[ -n "$(git -C "${repo_dir}" status --porcelain)" ]] && tree="dirty"
    quality_status="$(repo_quality_workflow_status "${repo_dir}" "${repo}")"
    print_kv "${repo}" "${branch} ${sha} ${tree} ci=${quality_status}"
  else
    print_kv "${repo}" "directory exists but is not a git repo"
  fi
done

compatibility_path="$(root_release_doc_path "$(root_compatibility_matrix_relative_path)")"
ci_standard_path="$(root_release_doc_path "$(root_ci_standard_relative_path)")"
echo "release policy inputs:"
echo "- Compatibility matrix: $([[ -f "${compatibility_path}" ]] && echo present || echo missing)"
echo "- CI standard: $([[ -f "${ci_standard_path}" ]] && echo present || echo missing)"
latest_audit="$(latest_release_audit_path || true)"
if [[ -n "${latest_audit}" ]]; then
  echo "- Latest release audit: ${latest_audit} ($(latest_release_audit_verdict || echo unknown))"
fi
echo "release policy status: $(release_policy_gap_message)"
