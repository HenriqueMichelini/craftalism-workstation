#!/usr/bin/env bash

set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "${root}/lib/common.sh"
source "${root}/lib/ci.sh"
source "${root}/lib/repo.sh"
source "${root}/lib/docs.sh"
source "${root}/lib/verify.sh"
source "${root}/lib/release.sh"
source "${root}/policy/release.sh"

repo_root="$(current_repo_root)"
repo_name="$(current_repo_name)"
require_managed_repo

print_kv "repo" "${repo_name}"
print_kv "docs state" "$(repo_docs_state "${repo_root}" "${repo_name}")"
print_kv "verify proof" "$(verify_state_for_head "${repo_name}")"
contract_checklist_path="$(root_release_doc_path "$(root_contract_change_checklist_relative_path)")"
compatibility_path="$(root_release_doc_path "$(root_compatibility_matrix_relative_path)")"
ci_standard_path="$(root_release_doc_path "$(root_ci_standard_relative_path)")"
latest_audit="$(latest_release_audit_path || true)"

if [[ -f "${contract_checklist_path}" ]]; then
  print_kv "contract checklist" "present"
else
  print_kv "contract checklist" "missing"
fi

if [[ -f "${compatibility_path}" ]]; then
  if compatibility_matrix_mentions_repo "${repo_name}"; then
    print_kv "compatibility matrix" "present and lists repo"
  else
    print_kv "compatibility matrix" "present but repo is not listed explicitly"
  fi
else
  print_kv "compatibility matrix" "missing"
fi

if [[ -f "${ci_standard_path}" ]]; then
  print_kv "ci standard" "present"
else
  print_kv "ci standard" "missing"
fi

print_kv "quality workflow" "$(repo_quality_workflow_status "${repo_root}" "${repo_name}")"
print_kv "release workflow" "$(repo_release_workflow_status "${repo_root}" "${repo_name}")"

if [[ -n "${latest_audit}" ]]; then
  print_kv "release audit" "$(latest_release_audit_verdict || echo unknown) ${latest_audit}"
else
  print_kv "release audit" "missing"
fi

echo "missing release policy inputs:"
while IFS= read -r line; do
  [[ -n "${line}" ]] && echo "- ${line}"
done < <(release_policy_missing_inputs)
