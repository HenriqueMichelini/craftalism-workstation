#!/usr/bin/env bash

set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "usage: work-tag <tag>" >&2
  exit 1
fi

tag="$1"
root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "${root}/lib/common.sh"
source "${root}/lib/ci.sh"
source "${root}/lib/repo.sh"
source "${root}/lib/release_report.sh"
source "${root}/lib/verify.sh"
source "${root}/lib/release.sh"
source "${root}/policy/repos.sh"
source "${root}/policy/ci.sh"
source "${root}/policy/release.sh"

repo_name="$(current_repo_name)"
repo_root="$(current_repo_root)"
require_managed_repo
latest_audit="$(latest_release_audit_path || true)"

repo_is_taggable "${repo_name}" || die "repo '${repo_name}' is not taggable"
[[ "${tag}" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]] || die "tag must match v<major>.<minor>.<patch>"
branch_state="$(release_gate_branch_state)"
tree_state="$(release_gate_tree_state)"
pushed_state="$(release_gate_pushed_state)"
verify_state="$(release_gate_verify_state "${repo_name}")"
compatibility_state="$(release_gate_compatibility_state "${repo_name}")"
ci_standard_state="$(release_gate_ci_standard_state)"
contract_checklist_state="$(release_gate_contract_checklist_state)"
quality_workflow_state="$(repo_quality_workflow_status "${repo_root}" "${repo_name}")"
release_workflow_state="$(repo_release_workflow_status "${repo_root}" "${repo_name}")"
ci_release_summary="$(repo_ci_release_summary "${repo_root}" "${repo_name}")"
latest_audit_state="$(release_gate_audit_state)"
decision="$(release_gate_decision "${branch_state}" "${tree_state}" "${pushed_state}" "${verify_state}" "${compatibility_state}" "${ci_standard_state}" "${contract_checklist_state}" "${ci_release_summary}" "${latest_audit_state}")"
blocking_reasons="$(print_release_blocking_reasons "${branch_state}" "${tree_state}" "${pushed_state}" "${verify_state}" "${compatibility_state}" "${latest_audit_state}")"

print_kv "tag" "${tag}"
print_kv "repo" "${repo_name}"
print_kv "branch gate" "${branch_state}"
print_kv "tree gate" "${tree_state}"
print_kv "pushed gate" "${pushed_state}"
print_kv "verify gate" "${verify_state}"
print_kv "compatibility" "${compatibility_state}"
print_kv "ci standard" "${ci_standard_state}"
print_kv "contract checklist" "${contract_checklist_state}"
print_kv "quality workflow" "${quality_workflow_state}"
print_kv "release workflow" "${release_workflow_state}"
print_kv "ci release summary" "${ci_release_summary}"
if [[ -n "${latest_audit}" ]]; then
  print_kv "release audit" "${latest_audit_state} ${latest_audit}"
else
  print_kv "release audit" "${latest_audit_state}"
fi
print_kv "decision" "${decision}"

echo "remaining policy gaps:"
while IFS= read -r line; do
  [[ -n "${line}" ]] && echo "- ${line}"
done < <(release_policy_missing_inputs)

if [[ -n "${blocking_reasons}" ]]; then
  echo "blocking reasons:"
  printf '%s\n' "${blocking_reasons}"
fi

[[ "${decision}" == "ready-for-next-release-gate" ]] || exit 1
